<view class="page">


<view class="title">
评价课程
</view>


<view class="score-card">


<text class="label">
课程评分
</text>


<view class="stars">


<text
wx:for="{{stars}}"
wx:key="index"
class="star {{score>=item?'active':''}}"
data-score="{{item}}"
bindtap="chooseScore"
>
★
</text>


</view>



<textarea

placeholder="请输入课程评价"

bindinput="inputContent"

/>



<button

class="submit-btn"

bindtap="submitReview"

>

提交评价

</button>



</view>


</view>