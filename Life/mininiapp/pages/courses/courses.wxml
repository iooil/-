<view class="page">
  <view class="search-section">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索课程、课程编号或教师"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        confirm-type="search"
        bindconfirm="handleSearch"
      />

      <view
        wx:if="{{keyword}}"
        class="clear-button"
        bindtap="handleClear"
      >
        清除
      </view>

      <button
        class="search-button"
        bindtap="handleSearch"
      >
        搜索
      </button>
    </view>

    <view class="filter-row">
      <picker
        class="filter-picker"
        mode="selector"
        range="{{colleges}}"
        value="{{collegeIndex}}"
        bindchange="onCollegeChange"
      >
        <view class="filter-content">
          <text>{{colleges[collegeIndex]}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>

      <picker
        class="filter-picker"
        mode="selector"
        range="{{courseTypes}}"
        value="{{typeIndex}}"
        bindchange="onTypeChange"
      >
        <view class="filter-content">
          <text>{{courseTypes[typeIndex]}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="summary">
    <text>共找到{{courses.length}}门课程</text>
    <text class="refresh-tip">下拉可刷新</text>
  </view>

  <view
    wx:if="{{loading}}"
    class="loading"
  >
    正在加载课程……
  </view>

  <view
    wx:elif="{{courses.length === 0}}"
    class="empty"
  >
    <view class="empty-icon">课</view>
    <text class="empty-title">
      暂无符合条件的课程
    </text>
    <text class="empty-desc">
      请尝试更换搜索词或筛选条件
    </text>
  </view>

  <view
    wx:else
    class="course-list"
  >
    <view
      wx:for="{{courses}}"
      wx:key="id"
      class="course-card"
    >
      <view class="course-header">
        <view class="course-main">
          <text class="course-name">
            {{item.course_name}}
          </text>

          <text class="course-no">
            {{item.course_no}}
          </text>
        </view>

        <view class="type-tag">
          {{item.course_type}}
        </view>
      </view>

      <view class="teacher-row">
        <text class="teacher-name">
          {{item.teacher_name}}
        </text>

        <text
          wx:if="{{item.teacher_title}}"
          class="teacher-title"
        >
          {{item.teacher_title}}
        </text>
      </view>

      <view class="course-info">
        <view class="info-item">
          <text class="info-label">学院</text>
          <text class="info-value">
            {{item.college}}
          </text>
        </view>

        <view class="info-item">
          <text class="info-label">学分</text>
          <text class="info-value">
            {{item.credit}}
          </text>
        </view>

        <view class="info-item">
          <text class="info-label">评分</text>
          <text class="score">
            {{item.score_text}}
          </text>
        </view>
      </view>

      <view class="description">
        {{item.description || '暂无课程简介'}}
      </view>

      <view class="capacity-row">
        <view class="capacity-text">
          <text>
            已选{{item.selected_count}}/{{item.capacity}}
          </text>

          <text
            class="{{item.remaining > 0 ? 'remaining' : 'full'}}"
          >
            {{item.remaining > 0
              ? '剩余' + item.remaining + '个名额'
              : '已满员'}}
          </text>
        </view>

        <view class="progress">
          <view
            class="progress-inner"
            style="width: {{item.progress_percent}}"
          ></view>
        </view>
      </view>

      <button
        class="{{item.is_selected
          ? 'selected-button'
          : item.remaining <= 0
          ? 'disabled-button'
          : 'select-button'}}"
        disabled="{{item.is_selected || item.remaining <= 0}}"
        data-course="{{item}}"
        bindtap="handleSelect"
      >
        {{item.is_selected
          ? '已选课程'
          : item.remaining <= 0
          ? '课程已满'
          : '立即选课'}}
      </button>
    </view>
  </view>
</view>