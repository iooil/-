page {

  background-color:#f5f7fb;
  
  }
  
  
  
  .page {
  
  min-height:100vh;
  
  padding:80rpx 50rpx;
  
  box-sizing:border-box;
  
  display:flex;
  
  flex-direction:column;
  
  align-items:center;
  
  }
  
  
  
  .school-logo {
  
  
  width:220rpx;
  
  height:220rpx;
  
  
  margin-top:30rpx;
  
  
  }
  
  
  
  .school-name {
  
  
  margin-top:30rpx;
  
  
  font-size:42rpx;
  
  
  font-weight:bold;
  
  
  color:#1e3a8a;
  
  
  }
  
  
  
  .system-name {
  
  
  margin-top:15rpx;
  
  
  font-size:48rpx;
  
  
  font-weight:bold;
  
  
  color:#111827;
  
  
  }
  
  
  
  .subtitle {
  
  
  margin-top:15rpx;
  
  
  font-size:26rpx;
  
  
  color:#6b7280;
  
  
  }
  
  
  
  .form-card {
  
  
  width:100%;
  
  
  margin-top:70rpx;
  
  
  padding:45rpx;
  
  
  background:white;
  
  
  border-radius:30rpx;
  
  
  box-sizing:border-box;
  
  
  box-shadow:
  
  0 15rpx 40rpx rgba(0,0,0,0.08);
  
  
  }
  
  
  
  .form-item {
  
  
  margin-bottom:35rpx;
  
  
  }
  
  
  
  .input {
  
  
  height:90rpx;
  
  
  padding:0 30rpx;
  
  
  background:#f8fafc;
  
  
  border-radius:45rpx;
  
  
  font-size:30rpx;
  
  
  border:1rpx solid #e5e7eb;
  
  
  }
  
  
  
  .login-btn {
  
  
  margin-top:20rpx;
  
  
  height:90rpx;
  
  
  line-height:90rpx;
  
  
  color:white;
  
  
  background:#1e40af;
  
  
  border-radius:45rpx;
  
  
  font-size:32rpx;
  
  
  }
  
  
  
  .register-link {
  
  
  margin-top:35rpx;
  
  
  text-align:center;
  
  
  font-size:28rpx;
  
  
  color:#2563eb;
  
  
  }