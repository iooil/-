<view class="page">


<view
wx:if="{{courses.length===0}}"
class="empty"
>

暂无已选课程

</view>



<view
wx:for="{{courses}}"
wx:key="id"
class="course-card"
>


<view class="top">


<text class="name">

{{item.course_name}}

</text>


<text class="credit">

{{item.credit}}学分

</text>


</view>



<text>

课程编号：
{{item.course_no}}

</text>


<text>

授课教师：
{{item.teacher_name}}

</text>


<text>

学院：
{{item.college}}

</text>



<text>

选课时间：
{{item.selected_at}}

</text>



<view class="buttons">


<button

size="mini"

type="warn"

data-id="{{item.id}}"

bindtap="dropCourse"

>

退课

</button>

<button
  size="mini"
  data-id="{{item.id}}"
  bindtap="evaluateCourse"
>
评价课程
</button>

<button
size="mini"
data-teacher="{{item.teacher_id}}"
data-course="{{item.id}}"
bindtap="evaluateTeacher"
>
评价教师
</button>

</view>



</view>

</view>