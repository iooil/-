<view class="page">
  <view class="header">
    <text class="title">创建学生账号</text>
    <text class="subtitle">请填写真实信息</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">学号</text>
      <input
        class="input"
        placeholder="请输入学号"
        value="{{studentNo}}"
        bindinput="onStudentNoInput"
      />
    </view>

    <view class="form-item">
      <text class="label">姓名</text>
      <input
        class="input"
        placeholder="请输入姓名"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <text class="label">专业</text>
      <input
        class="input"
        placeholder="请输入专业"
        value="{{major}}"
        bindinput="onMajorInput"
      />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input"
        password
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="form-item">
      <text class="label">确认密码</text>
      <input
        class="input"
        password
        placeholder="请再次输入密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <button class="register-btn" bindtap="handleRegister">
      注册
    </button>
  </view>
</view>