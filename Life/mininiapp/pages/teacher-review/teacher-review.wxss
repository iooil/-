page{

  background:#f5f7fb;
  
  }
  
  
  .page{
  
  padding:40rpx;
  
  }
  
  
  .title{
  
  text-align:center;
  
  font-size:42rpx;
  
  font-weight:bold;
  
  margin-bottom:50rpx;
  
  }
  
  
  
  .card{
  
  padding:40rpx;
  
  background:white;
  
  border-radius:25rpx;
  
  }
  
  
  
  .label{
  
  font-size:32rpx;
  
  font-weight:bold;
  
  }
  
  
  
  .stars{
  
  display:flex;
  
  justify-content:center;
  
  margin:50rpx 0;
  
  }
  
  
  
  .star{
  
  font-size:70rpx;
  
  color:#d1d5db;
  
  margin:0 10rpx;
  
  }
  
  
  
  .star.active{
  
  color:#f59e0b;
  
  }
  
  
  
  textarea{
  
  width:100%;
  
  height:250rpx;
  
  padding:25rpx;
  
  box-sizing:border-box;
  
  background:#f9fafb;
  
  border-radius:20rpx;
  
  }
  
  
  
  .submit-btn{
  
  margin-top:50rpx;
  
  color:white;
  
  background:#2563eb;
  
  border-radius:50rpx;
  
  }