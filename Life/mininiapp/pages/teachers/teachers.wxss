page {
  background-color: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding-bottom: 50rpx;
}

.search-section {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 25rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 25rpx;
  background-color: #f4f6f8;
  border-radius: 38rpx 0 0 38rpx;
  box-sizing: border-box;
  font-size: 27rpx;
}

.clear-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90rpx;
  height: 76rpx;
  color: #6b7280;
  background-color: #f4f6f8;
  font-size: 23rpx;
}

.search-button {
  width: 125rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  color: #ffffff;
  line-height: 76rpx;
  background-color: #16a34a;
  border-radius: 0 38rpx 38rpx 0;
  font-size: 27rpx;
}

.search-button::after {
  border: none;
}

.filter-content {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  padding: 20rpx;
  color: #4b5563;
  background-color: #f4f6f8;
  border-radius: 16rpx;
  font-size: 25rpx;
}

.arrow {
  margin-left: 12rpx;
  color: #9ca3af;
  font-size: 18rpx;
}

.summary {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 35rpx 10rpx;
  color: #4b5563;
  font-size: 25rpx;
}

.refresh-tip {
  color: #9ca3af;
}

.loading,
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 150rpx;
  color: #9ca3af;
  flex-direction: column;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  color: #ffffff;
  background-color: #86efac;
  border-radius: 28rpx;
  font-size: 44rpx;
}

.empty-title {
  margin-top: 30rpx;
  color: #4b5563;
  font-size: 30rpx;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.teacher-list {
  padding: 20rpx 30rpx;
}

.teacher-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(31, 41, 55, 0.06);
}

.teacher-top {
  display: flex;
  align-items: center;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 105rpx;
  height: 105rpx;
  margin-right: 25rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #16a34a, #4ade80);
  border-radius: 50%;
}

.teacher-main {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
}

.teacher-name {
  color: #1f2937;
  font-size: 34rpx;
  font-weight: bold;
}

.title-tag {
  margin-left: 15rpx;
  padding: 6rpx 14rpx;
  color: #059669;
  background-color: #ecfdf5;
  border-radius: 18rpx;
  font-size: 21rpx;
}

.teacher-no {
  margin-top: 11rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.college {
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 25rpx;
}

.detail-arrow {
  color: #cbd5e1;
  font-size: 55rpx;
}

.statistics {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 24rpx 10rpx;
  background-color: #f8fafc;
  border-radius: 18rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  width: 33.33%;
  flex-direction: column;
}

.stat-value {
  color: #374151;
  font-size: 24rpx;
  font-weight: bold;
}

.score {
  color: #f59e0b;
  font-size: 30rpx;
}

.stat-label {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 21rpx;
}

.divider {
  width: 1rpx;
  height: 55rpx;
  background-color: #e5e7eb;
}

.introduction {
  display: flex;
  margin-top: 25rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-direction: column;
}

.intro-label {
  color: #374151;
  font-size: 25rpx;
  font-weight: bold;
}

.intro-content {
  margin-top: 12rpx;
  color: #6b7280;
  line-height: 1.7;
  font-size: 24rpx;
}